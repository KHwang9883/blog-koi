---
interface Props {
    date: Date;
    class?: string;
}

const {date, class: className = ""} = Astro.props;
---

<time datetime={date.toISOString()} class={className}>{
    date.toLocaleDateString('zh-CN', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
    }).replace(/(\d+)/g, ' $1 ').trim()
}</time>
